ROOT_DOMAIN=
LAB_DOMAIN=
TAILNET_DOMAIN=
HEADSCALE_DOMAIN=

# Pre-auth key from Headscale (create with --tags tag:svc)
VAULT_AUTHKEY=

# Vaultwarden admin panel token (see README for generating a secure token)
VAULTWARDEN_ADMIN_TOKEN=

# LAN hostname for Vaultwarden (must match what your router resolves to this Pi)
LAN_DOMAIN=passwords.lan

# SMTP — leave blank to disable email (invitations, 2FA resets, etc.)
SMTP_HOST=
SMTP_FROM=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
