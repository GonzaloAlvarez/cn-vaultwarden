ROOT_DOMAIN=
# Tailnet IP of the VPS (run: docker exec cloudnet-headscale-1 headscale nodes list)
INFRA_VPS_TAILNET_IP=
LAB_DOMAIN=
TAILNET_DOMAIN=
HEADSCALE_DOMAIN=

# Pre-auth key from Headscale (create with --tags tag:svc)
VAULT_AUTHKEY=

# Vaultwarden admin panel token (see README for generating a secure token)
VAULTWARDEN_ADMIN_TOKEN=

# LAN hostname for Vaultwarden (must match what your router resolves to this Pi)
LAN_DOMAIN=passwords.lan

# SMTP — used by Vaultwarden (invitations, 2FA resets) and Watchtower (update notifications)
SMTP_HOST=
SMTP_FROM=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL=

# Backup — AWS S3
BACKUP_S3_BUCKET=
BACKUP_AWS_ACCESS_KEY_ID=
BACKUP_AWS_SECRET_ACCESS_KEY=
BACKUP_AWS_REGION=us-east-1

# Backup — WebDAV
BACKUP_WEBDAV_URL=
BACKUP_WEBDAV_USER=
BACKUP_WEBDAV_PASSWORD=
